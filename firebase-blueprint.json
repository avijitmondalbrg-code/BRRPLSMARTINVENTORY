{
  "entities": {
    "HearingAid": {
      "title": "Hearing Aid",
      "description": "A single hearing aid unit in inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "price": { "type": "number" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["Available", "Sold", "In-Transit"] },
        "addedDate": { "type": "string", "format": "date" },
        "hsnCode": { "type": "string" },
        "gstRate": { "type": "number" }
      },
      "required": ["id", "brand", "model", "serialNumber", "price", "location", "status"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "A supplier of hearing aids or other goods",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "gstin": { "type": "string" },
        "addedDate": { "type": "string", "format": "date" }
      },
      "required": ["id", "name"]
    },
    "PurchaseRecord": {
      "title": "Purchase Record",
      "description": "A record of a purchase from a vendor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "invoiceNo": { "type": "string" },
        "invoiceDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "hsnCode": { "type": "string" },
        "mrp": { "type": "number" },
        "discountAmount": { "type": "number" },
        "purchaseAmount": { "type": "number" },
        "location": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "vendorId", "serialNumber", "purchaseAmount"]
    },
    "Patient": {
      "title": "Patient",
      "description": "A customer or patient of the clinic",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "referDoctor": { "type": "string" },
        "audiologist": { "type": "string" },
        "gstin": { "type": "string" },
        "addedDate": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "dob": { "type": "string", "format": "date" }
      },
      "required": ["id", "name", "phone"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A sales invoice for a patient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "finalTotal": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Partial", "Unpaid"] },
        "balanceDue": { "type": "number" }
      },
      "required": ["id", "patientId", "finalTotal", "date"]
    },
    "FinancialNote": {
      "title": "Financial Note",
      "description": "A credit or debit note",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["CREDIT", "DEBIT"] },
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "reason": { "type": "string" },
        "targetId": { "type": "string" },
        "targetName": { "type": "string" }
      },
      "required": ["id", "type", "amount", "reason"]
    }
  },
  "firestore": {
    "inventory": { "schema": "HearingAid", "description": "Hearing aid inventory" },
    "vendors": { "schema": "Vendor", "description": "Suppliers" },
    "purchases": { "schema": "PurchaseRecord", "description": "Purchase history" },
    "patients": { "schema": "Patient", "description": "Patient database" },
    "invoices": { "schema": "Invoice", "description": "Sales invoices" },
    "demoInvoices": { "schema": "Invoice", "description": "Demo invoices" },
    "serviceInvoices": { "schema": "Invoice", "description": "Service invoices" },
    "financialNotes": { "schema": "FinancialNote", "description": "Credit/Debit notes" },
    "hospitals": { "schema": "object", "description": "Hospital details" },
    "quotations": { "schema": "object", "description": "Sales quotations" },
    "leads": { "schema": "object", "description": "CRM leads" },
    "stockTransfers": { "schema": "object", "description": "Internal stock movements" },
    "assetTransfers": { "schema": "object", "description": "Company asset movements" },
    "advanceBookings": { "schema": "object", "description": "Patient advance payments" },
    "companyAssets": { "schema": "object", "description": "Fixed assets" },
    "settings": { "schema": "object", "description": "App settings" }
  }
}
