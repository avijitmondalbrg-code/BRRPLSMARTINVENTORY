{
  "entities": {
    "HearingAid": {
      "title": "Hearing Aid",
      "description": "Inventory item for hearing aids",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "price": { "type": "number" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["Available", "Sold", "In-Transit"] },
        "addedDate": { "type": "string", "format": "date-time" },
        "hsnCode": { "type": "string" },
        "gstRate": { "type": "number" }
      },
      "required": ["id", "brand", "model", "serialNumber", "price", "location", "status", "addedDate"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Patient information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "referDoctor": { "type": "string" },
        "audiologist": { "type": "string" },
        "addedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "address", "phone", "referDoctor", "audiologist"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Sales invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "finalTotal": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Partial", "Unpaid"] }
      },
      "required": ["id", "patientId", "patientName", "finalTotal", "date", "paymentStatus"]
    },
    "AdvanceBooking": {
      "title": "Advance Booking",
      "description": "Advance token for bookings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Active", "Consumed", "Refunded"] }
      },
      "required": ["id", "patientId", "patientName", "amount", "date", "status"]
    }
  },
  "firestore": {
    "inventory": {
      "schema": "HearingAid",
      "description": "Collection of hearing aids in stock"
    },
    "patients": {
      "schema": "Patient",
      "description": "Collection of patient records"
    },
    "invoices": {
      "schema": "Invoice",
      "description": "Collection of sales invoices"
    },
    "advanceBookings": {
      "schema": "AdvanceBooking",
      "description": "Collection of advance bookings"
    }
  }
}
